{% include 'shogun-content-handler' %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  {% comment %}FIX 11: EN-first title tag{% endcomment %}
  <title>{% if template == 'index' %}Magic Moon Shop — Professional Tattoo Supply Since 1990{% elsif page_title %}{{ page_title }} — Magic Moon Shop{% else %}Magic Moon Shop{% endif %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;0,800;1,400&display=swap" rel="stylesheet">
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}

  {% render 'shogun-head' %}
</head>
<body>

<!-- ROW 1: Social + Amazon + Language -->
<div class="r1">
  <div class="wrap r1__in">
    <div class="r1__left">
      {% if settings.instagram_url != blank %}<a href="{{ settings.instagram_url }}" target="_blank" rel="noopener noreferrer" class="soc" aria-label="Instagram"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>{% endif %}
      {% if settings.facebook_url != blank %}<a href="{{ settings.facebook_url }}" target="_blank" rel="noopener noreferrer" class="soc" aria-label="Facebook"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{% endif %}
      {% if settings.linkedin_url != blank %}<a href="{{ settings.linkedin_url }}" target="_blank" rel="noopener noreferrer" class="soc" aria-label="LinkedIn"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>{% endif %}
      {% if settings.youtube_url != blank %}<a href="{{ settings.youtube_url }}" target="_blank" rel="noopener noreferrer" class="soc" aria-label="YouTube"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02"/></svg></a>{% endif %}
      {% if settings.tiktok_url != blank %}<a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" class="soc" aria-label="TikTok"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg></a>{% endif %}
      <span class="r1sep"></span>
      {% if settings.amazon_de_url != blank %}<a href="{{ settings.amazon_de_url }}" target="_blank" rel="noopener noreferrer" class="amz"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>Amazon DE</a>{% endif %}
      {% if settings.amazon_us_url != blank %}<a href="{{ settings.amazon_us_url }}" target="_blank" rel="noopener noreferrer" class="amz"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>Amazon USA</a>{% endif %}
    </div>
    <div class="r1__right">
      <div class="lang-sw">
        {% for locale in shop.published_locales %}
        <a href="{{ locale | locale_url }}" class="lang-btn{% if locale.iso_code == request.locale.iso_code %} active{% endif %}">{{ locale.iso_code | upcase | slice: 0, 2 }}</a>
        {% unless forloop.last %}<span class="lang-div"></span>{% endunless %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<!-- ROW 2: Logo + Info nav + Search + Cart -->
<header class="r2" role="banner">
  <div class="wrap r2__in">
    <a href="{{ routes.root_url }}" class="logo" aria-label="Magic Moon Shop">
      <div class="logo__moon" aria-hidden="true"></div>
      <div>
        <div class="logo__name">Magic Moon</div>
        <div class="logo__sub">{% if request.locale.iso_code == 'en' %}Professional Supply{% else %}Profi-Tätowierbedarf{% endif %}</div>
      </div>
    </a>
    <nav class="inav" aria-label="{% if request.locale.iso_code == 'en' %}Company{% else %}Unternehmen{% endif %}">
      {% comment %}FIX 10: Use locale_url filter instead of hardcoded /en/ prefix{% endcomment %}
      {% if request.locale.iso_code == 'en' %}
      <a href="{{ pages['about-us'].url | default: '/pages/about-us' }}" class="inl">About us</a>
      <a href="{{ pages['careers'].url | default: '/pages/careers' }}" class="inl">Careers</a>
      <a href="{{ pages['studio-offer'].url | default: '/pages/studio-offer' }}" class="inl">Studio Offer</a>
      <a href="{{ pages['sponsored-artists'].url | default: '/pages/sponsored-artists' }}" class="inl">Sponsored Artists</a>
      <a href="{{ blogs.news.url | default: '/blogs/news' }}" class="inl">News &amp; Blog</a>
      {% else %}
      <a href="{{ pages['ueber-uns'].url | default: '/pages/ueber-uns' }}" class="inl">Über uns</a>
      <a href="{{ pages['karriere'].url | default: '/pages/karriere' }}" class="inl">Karriere</a>
      <a href="{{ pages['studio-angebot'].url | default: '/pages/studio-angebot' }}" class="inl">Studio-Angebot</a>
      <a href="{{ pages['gesponserte-kuenstler'].url | default: '/pages/gesponserte-kuenstler' }}" class="inl">Gesponserte Künstler</a>
      <a href="{{ blogs.news.url | default: '/blogs/news' }}" class="inl">News &amp; Blog</a>
      {% endif %}
    </nav>
    <div class="r2__right">
      {% comment %}FIX 14: type="search" + hidden type=product for Shopify search scoping{% endcomment %}
      <form action="{{ routes.search_url }}" method="get" class="srch" role="search">
        <input type="hidden" name="type" value="product">
        <svg class="srch__ic" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" name="q" placeholder="{% if request.locale.iso_code == 'en' %}Search products…{% else %}Produkte suchen…{% endif %}" autocomplete="off" aria-label="{% if request.locale.iso_code == 'en' %}Search{% else %}Suchen{% endif %}">
      </form>
      {% if shop.customer_accounts_enabled %}
      <a href="{{ routes.account_url }}" class="hbtn" aria-label="{% if request.locale.iso_code == 'en' %}Account{% else %}Konto{% endif %}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      {% endif %}
      <button class="hbtn cart-open" id="cart-open" aria-label="{% if request.locale.iso_code == 'en' %}Open cart{% else %}Warenkorb öffnen{% endif %}" aria-controls="cart-drawer" aria-expanded="false">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-count" id="cart-count"{% if cart.item_count == 0 %} hidden{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>
</header>

{% comment %}FIX 12: escape announcement text to prevent XSS from admin input{% endcomment %}
{% if settings.announcement_text != blank %}
<div class="ann">{{ settings.announcement_text | escape }}</div>
{% endif %}

<main id="main" tabindex="-1">{{ content_for_layout }}</main>

<!-- CART DRAWER -->
<div id="cart-drawer" class="drawer" aria-hidden="true" role="dialog" aria-modal="true" aria-label="{% if request.locale.iso_code == 'en' %}Cart{% else %}Warenkorb{% endif %}">
  <div class="drawer__bg" id="cart-bg"></div>
  <div class="drawer__panel">
    <div class="drawer__hdr">
      <span class="drawer__title">{% if request.locale.iso_code == 'en' %}Cart{% else %}Warenkorb{% endif %}</span>
      <span class="drawer__count" id="dc">{{ cart.item_count }} {% if request.locale.iso_code == 'en' %}items{% else %}Artikel{% endif %}</span>
      <button class="drawer__x" id="cart-close" aria-label="{% if request.locale.iso_code == 'en' %}Close cart{% else %}Warenkorb schließen{% endif %}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="drawer__body" id="di">
      {% if cart.item_count == 0 %}
      <p class="drawer__empty">{% if request.locale.iso_code == 'en' %}Your cart is empty{% else %}Der Warenkorb ist leer{% endif %}</p>
      {% else %}
      {% for item in cart.items %}
      <div class="ci" data-key="{{ item.key }}">
        <div class="ci__img">{% if item.image %}<img src="{{ item.image | img_url: '100x100', crop: 'center' }}" alt="{{ item.title | escape }}" width="52" height="52" loading="lazy">{% endif %}</div>
        <div class="ci__info">
          <div class="ci__vendor">{{ item.vendor | escape }}</div>
          <div class="ci__name">{{ item.product.title | escape }}</div>
          {% unless item.variant.title == 'Default Title' %}<div class="ci__var">{{ item.variant.title | escape }}</div>{% endunless %}
          <div class="ci__row">
            <div class="qc">
              <button class="qb" data-key="{{ item.key }}" data-d="-1" aria-label="{% if request.locale.iso_code == 'en' %}Decrease{% else %}Weniger{% endif %}">−</button>
              <span class="qv">{{ item.quantity }}</span>
              <button class="qb" data-key="{{ item.key }}" data-d="1" aria-label="{% if request.locale.iso_code == 'en' %}Increase{% else %}Mehr{% endif %}">+</button>
            </div>
            <span class="ci__price">{{ item.final_line_price | money }}</span>
          </div>
        </div>
      </div>
      {% endfor %}
      {% endif %}
    </div>
    {% comment %}FIX 8: footer always rendered, shown/hidden via JS{% endcomment %}
    <div class="drawer__foot" id="df"{% if cart.item_count == 0 %} style="display:none"{% endif %}>
      <div class="drawer__total">
        <span>{% if request.locale.iso_code == 'en' %}Subtotal{% else %}Zwischensumme{% endif %}</span>
        <span id="dt">{{ cart.total_price | money }}</span>
      </div>
      <p class="drawer__note">{% if request.locale.iso_code == 'en' %}Shipping &amp; taxes calculated at checkout{% else %}Versand und Steuern werden an der Kasse berechnet{% endif %}</p>
      <a href="{{ routes.checkout }}" class="btn-r btn-full">{% if request.locale.iso_code == 'en' %}Checkout →{% else %}Zur Kasse →{% endif %}</a>
      <button class="btn-g btn-full mtop" id="cart-continue">{% if request.locale.iso_code == 'en' %}Continue shopping{% else %}Weiter einkaufen{% endif %}</button>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer class="footer" role="contentinfo">
  <div class="wrap footer__grid">
    <div>
      <div class="f-logo"><div class="f-moon" aria-hidden="true"></div><span class="f-name">Magic Moon Shop</span></div>
      <p class="f-tag">{% if request.locale.iso_code == 'en' %}Professional tattoo supplies for artists — since 1990.{% else %}Professioneller Tattoo-Bedarf für Künstler — seit 1990.{% endif %}</p>
      <p class="f-con">📍 Erkelenzer Straße 30, 41844 Wegberg, Deutschland</p>
      {% if settings.phone != blank %}<p class="f-con">📞 {{ settings.phone | escape }}</p>{% endif %}
      <p class="f-con">✉ {{ shop.email | escape }}</p>
      <div class="f-soc">
        {% if settings.instagram_url != blank %}<a href="{{ settings.instagram_url }}" target="_blank" rel="noopener noreferrer" class="f-si" aria-label="Instagram"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg></a>{% endif %}
        {% if settings.facebook_url != blank %}<a href="{{ settings.facebook_url }}" target="_blank" rel="noopener noreferrer" class="f-si" aria-label="Facebook"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>{% endif %}
        {% if settings.linkedin_url != blank %}<a href="{{ settings.linkedin_url }}" target="_blank" rel="noopener noreferrer" class="f-si" aria-label="LinkedIn"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>{% endif %}
        {% if settings.youtube_url != blank %}<a href="{{ settings.youtube_url }}" target="_blank" rel="noopener noreferrer" class="f-si" aria-label="YouTube"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02"/></svg></a>{% endif %}
        {% if settings.tiktok_url != blank %}<a href="{{ settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" class="f-si" aria-label="TikTok"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg></a>{% endif %}
      </div>
    </div>
    <div class="f-col">
      <h4>Shop</h4>
      {% for link in linklists.footer-shop.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}
    </div>
    <div class="f-col">
      <h4>{% if request.locale.iso_code == 'en' %}Company{% else %}Unternehmen{% endif %}</h4>
      {% for link in linklists.footer-company.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}
    </div>
    <div class="f-col">
      <h4>{% if request.locale.iso_code == 'en' %}Legal{% else %}Rechtliches{% endif %}</h4>
      {% for link in linklists.footer-legal.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}
    </div>
  </div>
  <div class="footer__bot">
    <div class="wrap footer__bot__in">
      <span>© {{ 'now' | date: '%Y' }} Magic Moon Shop · Wegberg, Deutschland</span>
      <div class="fbot-links">
        {% if request.locale.iso_code == 'en' %}
        <a href="/pages/datenschutz">Privacy Policy</a>
        <a href="/pages/impressum">Imprint</a>
        <a href="/pages/agb">Terms</a>
        <a href="/pages/widerrufsrecht">Withdrawal</a>
        {% else %}
        <a href="/pages/datenschutz">Datenschutz</a>
        <a href="/pages/impressum">Impressum</a>
        <a href="/pages/agb">AGB</a>
        <a href="/pages/widerrufsrecht">Widerruf</a>
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
