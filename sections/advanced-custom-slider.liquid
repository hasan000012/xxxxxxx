{% schema %}
{
  "name": "Advanced Custom Slider",
  "settings": [
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button Border Radius (px)",
      "default": 6,
      "min": 0,
      "max": 50
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button Font Size (px)",
      "default": 16,
      "min": 12,
      "max": 40
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "rgba(0,0,0,0.4)"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "slide_image", "label": "Background Image" },
        { "type": "text", "id": "slide_title", "label": "Title", "default": "Slide Title" },
        { "type": "text", "id": "slide_subtitle", "label": "Subtitle", "default": "Slide Subtitle" },
        { "type": "text", "id": "button1_text", "label": "Button 1 Text", "default": "Shop Now" },
        { "type": "url", "id": "button1_link", "label": "Button 1 Link" },
        { "type": "text", "id": "button2_text", "label": "Button 2 Text", "default": "Learn More" },
        { "type": "url", "id": "button2_link", "label": "Button 2 Link" }
      ]
    }
  ],
  "presets": [
    { "name": "Advanced Custom Slider", "category": "Hero" }
  ]
}
{% endschema %}

{% stylesheet %}
.custom-slider {
  position: relative;
  overflow: hidden;
  width: 100%;
  height: 520px;
}

.custom-slide {
  position: absolute;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  opacity: 0;
  transition: opacity 1s ease;
}

.custom-slide.active { opacity: 1; }

.custom-slide-overlay {
  position:absolute;
  width:100%;
  height:100%;
  background:{{ section.settings.overlay_color }};
  top:0; left:0; z-index:1;
}

.custom-slide-content {
  position:absolute; top:50%; left:50%;
  transform:translate(-50%,-50%);
  color:#fff; text-align:center; z-index:2;
  max-width:650px; width:90%;
}

.custom-slide-content h2 {
  font-size:48px; margin-bottom:10px; line-height:1.2;
}

.custom-slide-content p {
  font-size:20px; margin-bottom:25px;
}

.custom-slide-content a {
  padding:12px 25px;
  margin:8px;
  text-decoration:none;
  font-weight:600;
  border-radius:{{ section.settings.button_radius }}px;
  background:{{ section.settings.button_bg_color }};
  color:{{ section.settings.button_text_color }};
  font-size:{{ section.settings.button_font_size }}px;
  display:inline-block;
}

/* Arrows */
.custom-arrow {
  position:absolute; top:50%;
  transform:translateY(-50%); font-size:34px;
  color:#fff; cursor:pointer; z-index:20;
  padding:10px; opacity:0.8;
}
.custom-arrow-left { left:20px; }
.custom-arrow-right { right:20px; }

/* Dots */
.custom-dots {
  position:absolute; bottom:20px; width:100%; text-align:center;
}
.custom-dots span {
  width:12px; height:12px;
  background:rgba(255,255,255,0.6);
  display:inline-block; margin:5px;
  border-radius:50%; cursor:pointer;
}
.custom-dots .active { background:#fff; }

/* MOBILE */
@media(max-width:768px){
  .custom-slider { height:360px; }
  .custom-slide-content h2 { font-size:26px; }
  .custom-slide-content p { font-size:15px; margin-bottom:18px; }
  .custom-slide-content a {
    font-size:14px; padding:10px 18px;
    margin:5px 0; display:block;
  }
  .custom-arrow {
    font-size:26px; bottom:30px; top:auto;
  }
  .custom-arrow-left { left:15px; }
  .custom-arrow-right { right:15px; }
}
{% endstylesheet %}

<div class="custom-slider" id="slider">
  {% for block in section.blocks %}
    <div class="custom-slide {% if forloop.first %}active{% endif %}" 
         style="background-image:url('{{ block.settings.slide_image | img_url: '2048x2048' }}');">
         
      <div class="custom-slide-overlay"></div>

      <div class="custom-slide-content">
        <h2>{{ block.settings.slide_title }}</h2>
        <p>{{ block.settings.slide_subtitle }}</p>
        <a href="{{ block.settings.button1_link }}">{{ block.settings.button1_text }}</a>
        <a href="{{ block.settings.button2_link }}">{{ block.settings.button2_text }}</a>
      </div>

    </div>
  {% endfor %}

  <div class="custom-arrow custom-arrow-left" onclick="prevSlide()">❮</div>
  <div class="custom-arrow custom-arrow-right" onclick="nextSlide()">❯</div>

  <div class="custom-dots" id="dots"></div>
</div>

<script>
let currentSlide = 0;
let slides = document.querySelectorAll(".custom-slide");
let totalSlides = slides.length;
let dotsContainer = document.getElementById("dots");

/* Create Dots */
slides.forEach((_, index) => {
  let dot = document.createElement("span");
  dot.addEventListener("click", () => goToSlide(index));
  dotsContainer.appendChild(dot);
});
updateDots();

function showSlide(index){
  slides.forEach(s => s.classList.remove("active"));
  slides[index].classList.add("active");
  currentSlide = index;
  updateDots();
}

function nextSlide(){ showSlide((currentSlide+1)%totalSlides); }
function prevSlide(){ showSlide((currentSlide-1+totalSlides)%totalSlides); }
function goToSlide(i){ showSlide(i); }

function updateDots(){
  let dots = dotsContainer.children;
  for(let i=0;i<dots.length;i++){
    dots[i].classList.remove("active");
  }
  dots[currentSlide].classList.add("active");
}

/* Autoplay with pause */
let autoPlay = setInterval(nextSlide, 3500);
let slider = document.getElementById("slider");

slider.addEventListener("mouseenter",()=>clearInterval(autoPlay));
slider.addEventListener("mouseleave",()=>autoPlay=setInterval(nextSlide,3500));

/* Mobile Swipe */
let startX=0, endX=0;

slider.addEventListener("touchstart", e => {
  startX = e.changedTouches[0].clientX;
});

slider.addEventListener("touchend", e => {
  endX = e.changedTouches[0].clientX;
  handleSwipe();
});

function handleSwipe(){
  let diff = startX - endX;
  if(Math.abs(diff) > 50){
    diff > 0 ? nextSlide() : prevSlide();
  }
}
</script>