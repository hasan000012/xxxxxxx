    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/>
    </svg>
    Filters
    <span class="xuw-filter-badge" id="xuwFilterBadge" style="display:none" aria-live="polite">0</span>
  </button>

  <aside class="xuw-sidebar" id="xuwSidebar" aria-label="Product filters">
    <div class="xuw-sidebar__head">
      <span class="xuw-sidebar__title">Filters</span>
      <button class="xuw-clear-all" id="xuwClearAll" data-action="clear-all" type="button">Clear All</button>
    </div>

    {%- comment %}
    ── PURCHASE TYPE: Retail / Wholesale (value-based discount) ──
    No fixed MOQ. Discount tiers applied to cart total in JS.
    {% endcomment %}
    <div class="xuw-filter-group xuw-filter-group--ws">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="true" type="button">
        <span>Purchase Type</span>
        <svg class="xuw-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body">
        <div class="xuw-ws-toggle" role="group" aria-label="Purchase type">
          <button class="xuw-ws-btn is-active" data-mode="retail"    data-action="set-ws-mode" type="button">Retail</button>
          <button class="xuw-ws-btn"           data-mode="wholesale" data-action="set-ws-mode" type="button">Wholesale</button>
        </div>
        <p class="xuw-ws-note" id="xuwSidebarModeNote">Standard retail pricing</p>
        <div class="xuw-ws-tiers" id="xuwSidebarTiers" style="display:none">
          <p class="xuw-ws-tiers__label">Bulk discounts apply automatically:</p>
          <table class="xuw-ws-tiers__table">
            <tr><td>&#8364;300+</td><td class="xuw-ws-tiers__pct">3% off</td></tr>
            <tr><td>&#8364;500+</td><td class="xuw-ws-tiers__pct">5% off</td></tr>
            <tr><td>&#8364;1,000+</td><td class="xuw-ws-tiers__pct">10% off</td></tr>
            <tr><td>&#8364;2,000+</td><td class="xuw-ws-tiers__pct">20% off</td></tr>
          </table>
        </div>
      </div>
    </div>

    {%- comment %}
