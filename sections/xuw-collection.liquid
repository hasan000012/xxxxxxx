    </div>

  </aside>
  {%- endif -%}

  <main class="xuw-main" id="xuwMain">
    <div class="xuw-shop-header">
      <div class="xuw-product-count" aria-live="polite">
        <span id="xuwProductCount">{{ col.products_count }}</span>&thinsp;Products
      </div>
      <div class="xuw-search-bar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="xuwSearch" placeholder="Filter visible products…" autocomplete="off" aria-label="Filter products">
        <button class="xuw-search-clear" id="xuwSearchClear" data-action="clear-search" style="display:none" aria-label="Clear" type="button">&#10005;</button>
      </div>
      {%- if enable_sorting -%}
      <select class="xuw-sort-select" id="xuwSortSelect" aria-label="Sort products">
        {%- assign cur_sort = col.sort_by | default: '' -%}
        <option value="title-ascending"    {% if cur_sort == 'title-ascending'    %}selected{% endif %}>A – Z</option>
        <option value="title-descending"   {% if cur_sort == 'title-descending'   %}selected{% endif %}>Z – A</option>
        <option value="price-ascending"    {% if cur_sort == 'price-ascending'    %}selected{% endif %}>Price &#8593;</option>
        <option value="price-descending"   {% if cur_sort == 'price-descending'   %}selected{% endif %}>Price &#8595;</option>
        <option value="best-selling"       {% if cur_sort == 'best-selling'       %}selected{% endif %}>Best Selling</option>
        <option value="created-descending" {% if cur_sort == 'created-descending' %}selected{% endif %}>Newest</option>
      </select>
      {%- endif -%}
    </div>

    {%- if is_homepage -%}
      <div class="xuw-product-grid" id="xuwGrid" data-total="{{ col.products_count }}">
        {%- for product in col.products limit: products_per_page -%}
          {%- render 'xuw-product-card', product: product, show_vendor: show_vendor -%}
        {%- else -%}
          <div class="xuw-empty"><div class="xuw-empty__icon" aria-hidden="true">&#128269;</div><p>No products found.</p><a href="{{ routes.all_products_collection_url }}" class="xuw-btn xuw-btn--outline" style="display:inline-block;width:auto;margin-top:16px">Browse All</a></div>
        {%- endfor -%}
      </div>
      {%- if col.products_count > products_per_page -%}
        <div class="xuw-view-all-wrap">
          <a href="{{ col.url }}" class="xuw-btn xuw-btn--outline xuw-btn--view-all">View All {{ col.products_count }} Products &#8594;</a>
        </div>
      {%- endif -%}
    {%- else -%}
      {%- paginate col.products by products_per_page -%}
        <div class="xuw-product-grid" id="xuwGrid" data-total="{{ col.products_count }}">
          {%- for product in col.products -%}
            {%- render 'xuw-product-card', product: product, show_vendor: show_vendor -%}
          {%- else -%}
            <div class="xuw-empty"><div class="xuw-empty__icon" aria-hidden="true">&#128269;</div><p>No products found.</p></div>
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <nav class="xuw-pagination" aria-label="Product pages">
            {%- if paginate.previous -%}<a class="xuw-pg-btn" href="{{ paginate.previous.url }}" aria-label="Previous">&#8592;</a>{%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}<a class="xuw-pg-btn" href="{{ part.url }}">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}<span class="xuw-pg-btn is-active" aria-current="page">{{ part.title }}</span>
              {%- else -%}<span class="xuw-pg-btn xuw-pg-dots">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}<a class="xuw-pg-btn" href="{{ paginate.next.url }}" aria-label="Next">&#8594;</a>{%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  </main>
</div>

{%- comment %} Modal, toast, CSS and JS are now loaded globally via snippets/xuw-global.liquid in layout/theme.liquid {% endcomment %}

