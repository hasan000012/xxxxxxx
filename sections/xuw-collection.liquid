{%- comment %} ══ HOMEPAGE SECTIONS ══ {% endcomment %}
{%- if is_homepage -%}

{%- comment %}
  V6: Inline filter bar — HTML skeleton only. JS (_buildFilterBar) runs on
  DOMContentLoaded, scans .xuw-card elements, and populates #xuw-filter-groups
  with pills for needle-type, pin-count, vendor, availability, and mode.
  RISK-3 mitigation: top offset uses Horizon's own CSS custom properties —
  see .xuw-filter-bar rule in xuw-collection.css.
{% endcomment %}
<div id="xuw-filter-bar" class="xuw-filter-bar" role="region" aria-label="Product filters">
  <div class="xuw-filter-bar__inner">
    <div id="xuw-filter-groups" class="xuw-filter-groups"></div>
    <button class="xuw-filter-clear xuw-is-hidden"
            data-action="filter-clear"
            type="button"
            aria-label="Clear all filters">Clear all</button>
  </div>
  <div class="xuw-filter-bar__count" aria-live="polite" aria-atomic="true">
    <span id="xuw-visible-count"></span> products
  </div>
</div>

{%- comment %} Section 2: Quick-Category Pill Row — navigation strip, kept in V6 {% endcomment %}
<section class="xuw-section--hp" aria-label="Shop by category">
  <h2 class="xuw-section__heading">{{ section.settings.cat_strip_heading | default: 'Shop by Category' }}</h2>
  <div class="xuw-pill-row">
    <a class="xuw-cat-pill" href="/collections/magic-moon-needles">
      <span class="xuw-cat-pill__dot" aria-hidden="true"></span>Needles
    </a>
    <a class="xuw-cat-pill" href="/collections/magic-moon-cartridges">
      <span class="xuw-cat-pill__dot" aria-hidden="true"></span>Cartridges
    </a>
    <a class="xuw-cat-pill" href="/collections/tattoo-inks">
      <span class="xuw-cat-pill__dot" aria-hidden="true"></span>Inks
    </a>
    <a class="xuw-cat-pill" href="/collections/tattoo-machines">
      <span class="xuw-cat-pill__dot" aria-hidden="true"></span>Machines
    </a>
    <a class="xuw-cat-pill" href="/collections/tattoo-aftercare-products">
      <span class="xuw-cat-pill__dot" aria-hidden="true"></span>Aftercare
    </a>
    <a class="xuw-cat-pill" href="/collections/barrier-film-covers">
      <span class="xuw-cat-pill__dot" aria-hidden="true"></span>Hygiene
    </a>
  </div>
</section>

{%- comment %} Section 3: Featured Collection Grid {% endcomment %}
{%- assign featured_col = section.settings.featured_collection -%}
{%- if featured_col != blank -%}
<section class="xuw-section--hp" aria-label="Featured products">
  <h2 class="xuw-section__heading">{{ section.settings.featured_heading | default: 'Featured Products' }}</h2>
  <div class="xuw-grid">
    {%- for product in featured_col.products limit: 8 -%}
      {%- render 'xuw-product-card', product: product, show_vendor: show_vendor -%}
    {%- else -%}
      <p style="color:var(--xuw-muted)">No featured products yet.</p>
    {%- endfor -%}
  </div>
  <div style="text-align:center;margin-top:24px">
    <a href="{{ featured_col.url }}" class="xuw-btn xuw-btn--outline" style="display:inline-block;width:auto">View All &#8594;</a>
  </div>
</section>
{%- endif -%}

{%- comment %} Section 4: Brand Grid {% endcomment %}
{%- assign brand_blocks = section.blocks | where: 'type', 'brand' -%}
{%- if brand_blocks.size > 0 -%}
<section class="xuw-section--hp" aria-label="Our brands">
  <h2 class="xuw-section__heading">{{ section.settings.brands_heading | default: 'Our Brands' }}</h2>
  <div class="xuw-brand-grid">
    {%- for block in brand_blocks -%}
      {%- if block.settings.brand_url != blank -%}
        <a class="xuw-brand-logo" href="{{ block.settings.brand_url }}" {{ block.shopify_attributes }}>
      {%- else -%}
        <div class="xuw-brand-logo" {{ block.shopify_attributes }}>
      {%- endif -%}
      {%- if block.settings.brand_logo != blank -%}
        <img src="{{ block.settings.brand_logo | image_url: width: 200 }}" alt="{{ block.settings.brand_name | default: 'Brand' | escape }}" width="200" loading="lazy">
      {%- else -%}
        <span class="xuw-brand-logo__text">{{ block.settings.brand_name | default: 'Brand' }}</span>
      {%- endif -%}
      {%- if block.settings.brand_url != blank -%}</a>{%- else -%}</div>{%- endif -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{%- comment %} Section 5: Needle-Type Strip — schema needle_product blocks (V5) {% endcomment %}
{%- assign needle_blocks = section.blocks | where: 'type', 'needle_product' -%}
{%- if needle_blocks.size > 0 -%}
<section class="xuw-section--hp" aria-label="Shop by needle type">
  <h2 class="xuw-section__heading">{{ section.settings.needle_strip_heading | default: 'Shop by Needle Type' }}</h2>
  <div class="xuw-grid xuw-grid--5col">
    {%- for block in needle_blocks -%}
      {%- assign np = block.settings.product -%}
      {%- if np != blank -%}
        <a class="xuw-cat-tile xuw-cat-tile--needle" href="{{ np.url }}" {{ block.shopify_attributes }}>
          {%- if np.featured_media -%}
            <img class="xuw-cat-tile__img"
              src="{{ np.featured_media | image_url: width: 300 }}"
              alt="{{ np.title | escape }}" width="300" loading="lazy">
          {%- endif -%}
          <span class="xuw-cat-tile__label">{{ block.settings.label | default: np.title }}</span>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>
{%- endif -%}

{%- else -%}

{%- comment %} ══ SHOP WRAPPER ══ {% endcomment %}
<div class="xuw-shop-wrapper">

  {%- if enable_filtering -%}
  <button class="xuw-filter-mobile-btn" id="xuwFilterMobileBtn"
    data-action="toggle-sidebar" aria-expanded="false" aria-controls="xuwSidebar" type="button">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/>
    </svg>
    Filters
    <span class="xuw-filter-badge" id="xuwFilterBadge" style="display:none" aria-live="polite">0</span>
  </button>

  <aside class="xuw-sidebar" id="xuwSidebar" aria-label="Product filters">
    <div class="xuw-sidebar__head">
      <span class="xuw-sidebar__title">Filters</span>
      <button class="xuw-clear-all" id="xuwClearAll" data-action="clear-all" type="button">Clear All</button>
    </div>

    {%- comment %}
    ── PURCHASE TYPE: Retail / Wholesale (value-based discount) ──
    No fixed MOQ. Discount tiers applied to cart total in JS.
    {% endcomment %}
    <div class="xuw-filter-group xuw-filter-group--ws">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="true" type="button">
        <span>Purchase Type</span>
        <svg class="xuw-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body">
        <div class="xuw-ws-toggle" role="group" aria-label="Purchase type">
          <button class="xuw-ws-btn is-active" data-mode="retail"    data-action="set-ws-mode" type="button">Retail</button>
          <button class="xuw-ws-btn"           data-mode="wholesale" data-action="set-ws-mode" type="button">Wholesale</button>
        </div>
        <p class="xuw-ws-note" id="xuwSidebarModeNote">Standard retail pricing</p>
        <div class="xuw-ws-tiers" id="xuwSidebarTiers" style="display:none">
          <p class="xuw-ws-tiers__label">Bulk discounts apply automatically:</p>
          <table class="xuw-ws-tiers__table">
            <tr><td>&#8364;300+</td><td class="xuw-ws-tiers__pct">3% off</td></tr>
            <tr><td>&#8364;500+</td><td class="xuw-ws-tiers__pct">5% off</td></tr>
            <tr><td>&#8364;1,000+</td><td class="xuw-ws-tiers__pct">10% off</td></tr>
            <tr><td>&#8364;2,000+</td><td class="xuw-ws-tiers__pct">20% off</td></tr>
          </table>
        </div>
      </div>
    </div>

    {%- comment %}
    ── V6 DYNAMIC CATEGORY NAV ──────────────────────────────────────────────
    Reads from linklists['shop-categories'] (Shopify Admin → Navigation).
    RISK-2 mitigation: if menu handle is not configured or has no links, the
    for-loop produces nothing — no Liquid error, no broken sidebar.
    Each top-level link may have nested sub-links (2-level accordion).
    Active branch auto-opens based on current collection.handle match.
    ─────────────────────────────────────────────────────────────────────────
    {% endcomment %}
    {%- for link in linklists['shop-categories'].links -%}
      {%- comment %} Determine if this branch should be open {% endcomment %}
      {%- assign branch_open = false -%}
      {%- if collection != blank -%}
        {%- if link.url contains collection.handle -%}
          {%- assign branch_open = true -%}
        {%- endif -%}
        {%- for sub in link.links -%}
          {%- if sub.url contains collection.handle -%}
            {%- assign branch_open = true -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      <div class="xuw-filter-group xuw-cat-group">
        <button class="xuw-filter-group__head" data-action="toggle-group"
          aria-expanded="{{ branch_open }}" type="button">
          <span>{{ link.title }}</span>
          <svg class="xuw-chevron{% unless branch_open %} xuw-chevron--closed{% endunless %}"
            width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="xuw-cat-links"{% unless branch_open %} style="display:none"{% endunless %}>
          {%- if link.links.size > 0 -%}
            {%- for sub in link.links -%}
              {%- assign sub_active = false -%}
              {%- if collection != blank and sub.url contains collection.handle -%}
                {%- assign sub_active = true -%}
              {%- endif -%}
              <a href="{{ sub.url }}"
                class="xuw-cat-link{% if sub_active %} is-active{% endif %}">{{ sub.title }}</a>
            {%- endfor -%}
          {%- else -%}
            {%- assign top_active = false -%}
            {%- if collection != blank and link.url contains collection.handle -%}
              {%- assign top_active = true -%}
            {%- endif -%}
            <a href="{{ link.url }}"
              class="xuw-cat-link{% if top_active %} is-active{% endif %}">{{ link.title }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- comment %}
    ── PRODUCT ATTRIBUTE FILTERS (tag-based, for collection pages) ──
    These filter the VISIBLE cards on the current page via JS.
    On the individual collection page, Shopify Search & Discovery
    can also provide server-side filtering below.
    {% endcomment %}

    {%- comment %} Needle Type (Block 3: needle-type tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Needle Type</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign nt_labels = "Magnum,Round Liner,Round Shader,Soft Edge Magnum,Diamond,Slope Magnum,Specialty" | split: "," -%}
        {%- assign nt_slugs  = "magnum,round-liner,round-shader,soft-edge-magnum,diamond,slope-magnum,specialty" | split: "," -%}
        {%- for i in (0..6) -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="tags" data-filter-val="{{ nt_slugs[i] }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ nt_labels[i] }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Needle Count (Block 3: pin-count tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Needle Count</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        <div class="xuw-needle-grid">
          {%- assign needle_pins = "1,3,5,7,9,11,13,14,15,17,18,19,21,23,25" | split: "," -%}
          {%- for n in needle_pins -%}
            <button class="xuw-needle-pill" data-filter-key="tags" data-filter-val="{{ n }}-pin"
              data-action="needle-pill" aria-pressed="false" type="button">{{ n }}</button>
          {%- endfor -%}
        </div>
        <p class="xuw-hint">Tap a count to filter (e.g. 9-pin)</p>
      </div>
    </div>

    {%- comment %} Taper (Block 3: taper tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Taper</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign taper_labels = "Long Taper,Medium Taper,Short Taper,Standard" | split: "," -%}
        {%- assign taper_slugs  = "long-taper,medium-taper,short-taper,standard"  | split: "," -%}
        {%- for i in (0..3) -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="tags" data-filter-val="{{ taper_slugs[i] }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ taper_labels[i] }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Needle Config (Block 3: config tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Configuration</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign cfg_labels = "Open Magnum,Closed Magnum,Bugpin,Straight" | split: "," -%}
        {%- assign cfg_slugs  = "open-magnum,closed-magnum,bugpin,straight"  | split: "," -%}
        {%- for i in (0..3) -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="tags" data-filter-val="{{ cfg_slugs[i] }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ cfg_labels[i] }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Cartridge Line (Block 3: line tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Cartridge Line</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign line_labels = "Biodegradable,Comfort,Needle Cartridge,Slim Line" | split: "," -%}
        {%- assign line_slugs  = "biodegradable,comfort,needle-cartridge,slim-line"  | split: "," -%}
        {%- for i in (0..3) -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="tags" data-filter-val="{{ line_slugs[i] }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ line_labels[i] }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Cartridge Brand (Block 3: brand-slug tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Cartridge Brand</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign bslug_labels = "Magic Moon,Kwadron,Lunar PMU" | split: "," -%}
        {%- assign bslug_slugs  = "magic-moon,kwadron,lunar-pmu" | split: "," -%}
        {%- for i in (0..2) -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="tags" data-filter-val="{{ bslug_slugs[i] }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ bslug_labels[i] }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Ink Volume (Block 3: volume tag values) {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Ink Volume</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign volumes = "15ml,22ml,30ml,50ml,150ml" | split: "," -%}
        {%- for v in volumes -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="tags" data-filter-val="{{ v }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ v }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Brand — all 44 exact vendor strings from Block 3 {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="false" type="button">
        <span>Brand</span>
        <svg class="xuw-chevron xuw-chevron--closed" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body" style="display:none">
        {%- assign brands = "Magic Moon,Magic Moon Shop,Lunar PMU,UNI,Cheyenne,Critical,Kwadron,Tombow,Eberhard Faber,FK Irons,Unigloves,Neuma,Tattoo Workz,Legend,Musotoku,Spirit,Sara Pavo,Equaliser,I AM INK,InkTrox,Shagbuilt,Unistar,Dermalize,InkJecta,Stencil Stuff,Method,Hustle Butter,Maximo,Inklab,Polybius,Stigma-Rotary,ArtDriver,Dragonhawk,Nemesis,World Famous,Intenze,Kuro Sumi,Perma Blend,Panthera,Apex Eternal,Dynamic,Eclipse,Talens,Various" | split: "," -%}
        {%- for b in brands -%}
          <label class="xuw-check">
            <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="vendor" data-filter-val="{{ b | downcase }}">
            <span class="xuw-check__box"></span><span class="xuw-check__label">{{ b }}</span>
          </label>
        {%- endfor -%}
      </div>
    </div>

    {%- comment %} Availability {% endcomment %}
    <div class="xuw-filter-group">
      <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="true" type="button">
        <span>Availability</span>
        <svg class="xuw-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <div class="xuw-filter-group__body">
        <label class="xuw-check">
          <input type="checkbox" class="xuw-fc xuw-fc--static" data-filter-key="available" data-filter-val="true">
          <span class="xuw-check__box"></span><span class="xuw-check__label">In Stock Only</span>
        </label>
      </div>
    </div>

    {%- comment %} Search & Discovery dynamic filters (price range etc.) {% endcomment %}
    {%- if col.filters.size > 0 -%}
      {%- assign skip_labels = "Availability,Vendor,Brand,Product type,Product Type,Category" | split: "," -%}
      {%- for filter in col.filters -%}
        {%- assign skip = false -%}
        {%- for sl in skip_labels -%}{%- if filter.label == sl -%}{%- assign skip = true -%}{%- endif -%}{%- endfor -%}
        {%- unless skip -%}
          <div class="xuw-filter-group">
            <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="true" type="button">
              <span>{{ filter.label }}</span>
              <svg class="xuw-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="xuw-filter-group__body">
              {%- case filter.type -%}
                {%- when 'boolean' -%}
                  <label class="xuw-check">
                    <input type="checkbox" class="xuw-fc xuw-fc--dynamic"
                      {% if filter.active_values.size > 0 %}checked{% endif %}
                      data-add="{{ filter.values[0].url_to_add }}"
                      data-remove="{{ filter.values[0].url_to_remove }}">
                    <span class="xuw-check__box"></span><span class="xuw-check__label">{{ filter.label }}</span>
                  </label>
                {%- when 'list' -%}
                  {%- for value in filter.values -%}
                    <label class="xuw-check{% if value.count == 0 and value.active == false %} xuw-check--empty{% endif %}">
                      <input type="checkbox" class="xuw-fc xuw-fc--dynamic"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        data-add="{{ value.url_to_add }}" data-remove="{{ value.url_to_remove }}">
                      <span class="xuw-check__box"></span>
                      <span class="xuw-check__label">{{ value.label }}</span>
                      <span class="xuw-check__count">{{ value.count }}</span>
                    </label>
                  {%- endfor -%}
                {%- when 'price_range' -%}
                  <div class="xuw-price-range">
                    <div class="xuw-price-range__track">
                      <div class="xuw-price-range__fill" id="xuwPriceFill"></div>
                      <input type="range" class="xuw-range" id="xuwPriceMin"
                        min="{{ filter.range_min | divided_by: 100.0 }}" max="{{ filter.range_max | divided_by: 100.0 }}"
                        value="{{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 }}"
                        step="1" data-param="{{ filter.min_value.param_name }}" aria-label="Minimum price">
                      <input type="range" class="xuw-range" id="xuwPriceMax"
                        min="{{ filter.range_min | divided_by: 100.0 }}" max="{{ filter.range_max | divided_by: 100.0 }}"
                        value="{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 }}"
                        step="1" data-param="{{ filter.max_value.param_name }}" aria-label="Maximum price">
                    </div>
                    <div class="xuw-price-range__labels">
                      <span id="xuwPriceMinLbl">&#8364;{{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 | round }}</span>
                      <span id="xuwPriceMaxLbl">&#8364;{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 | round }}</span>
                    </div>
                  </div>
              {%- endcase -%}
            </div>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}

    <div class="xuw-active-chips" id="xuwActiveChips" style="display:none">
      <p class="xuw-active-chips__label">Active filters:</p>
      <div id="xuwChipList"></div>
    </div>

  </aside>
  {%- endif -%}

  <main class="xuw-main" id="xuwMain">
    <div class="xuw-shop-header">
      <div class="xuw-product-count" aria-live="polite">
        <span id="xuwProductCount">{{ col.products_count }}</span>&thinsp;Products
      </div>
      <div class="xuw-search-bar">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" id="xuwSearch" placeholder="Filter visible products…" autocomplete="off" aria-label="Filter products">
        <button class="xuw-search-clear" id="xuwSearchClear" data-action="clear-search" style="display:none" aria-label="Clear" type="button">&#10005;</button>
      </div>
      {%- if enable_sorting -%}
      <select class="xuw-sort-select" id="xuwSortSelect" aria-label="Sort products">
        {%- assign cur_sort = col.sort_by | default: '' -%}
        <option value="title-ascending"    {% if cur_sort == 'title-ascending'    %}selected{% endif %}>A – Z</option>
        <option value="title-descending"   {% if cur_sort == 'title-descending'   %}selected{% endif %}>Z – A</option>
        <option value="price-ascending"    {% if cur_sort == 'price-ascending'    %}selected{% endif %}>Price &#8593;</option>
        <option value="price-descending"   {% if cur_sort == 'price-descending'   %}selected{% endif %}>Price &#8595;</option>
        <option value="best-selling"       {% if cur_sort == 'best-selling'       %}selected{% endif %}>Best Selling</option>
        <option value="created-descending" {% if cur_sort == 'created-descending' %}selected{% endif %}>Newest</option>
      </select>
      {%- endif -%}
    </div>

    {%- paginate col.products by products_per_page -%}
      <div class="xuw-product-grid" id="xuwGrid" data-total="{{ col.products_count }}">
        {%- for product in col.products -%}
          {%- render 'xuw-product-card', product: product, show_vendor: show_vendor -%}
        {%- else -%}
          <div class="xuw-empty"><div class="xuw-empty__icon" aria-hidden="true">&#128269;</div><p>No products found.</p></div>
        {%- endfor -%}
      </div>
      {%- if paginate.pages > 1 -%}
        <nav class="xuw-pagination" aria-label="Product pages">
          {%- if paginate.previous -%}<a class="xuw-pg-btn" href="{{ paginate.previous.url }}" aria-label="Previous">&#8592;</a>{%- endif -%}
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a class="xuw-pg-btn" href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}<span class="xuw-pg-btn is-active" aria-current="page">{{ part.title }}</span>
            {%- else -%}<span class="xuw-pg-btn xuw-pg-dots">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
          {%- if paginate.next -%}<a class="xuw-pg-btn" href="{{ paginate.next.url }}" aria-label="Next">&#8594;</a>{%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </main>
</div>

{%- endif -%}

{%- comment %} Modal, toast, CSS and JS are now loaded globally via snippets/xuw-global.liquid in layout/theme.liquid {% endcomment %}

