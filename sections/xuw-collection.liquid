    {%- comment %} Search & Discovery dynamic filters (price range etc.) {% endcomment %}
    {%- if col.filters.size > 0 -%}
      {%- assign skip_labels = "Availability,Vendor,Brand,Product type,Product Type,Category" | split: "," -%}
      {%- for filter in col.filters -%}
        {%- assign skip = false -%}
        {%- for sl in skip_labels -%}{%- if filter.label == sl -%}{%- assign skip = true -%}{%- endif -%}{%- endfor -%}
        {%- unless skip -%}
          <div class="xuw-filter-group">
            <button class="xuw-filter-group__head" data-action="toggle-group" aria-expanded="true" type="button">
              <span>{{ filter.label }}</span>
              <svg class="xuw-chevron" width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </button>
            <div class="xuw-filter-group__body">
              {%- case filter.type -%}
                {%- when 'boolean' -%}
                  <label class="xuw-check">
                    <input type="checkbox" class="xuw-fc xuw-fc--dynamic"
                      {% if filter.active_values.size > 0 %}checked{% endif %}
                      data-add="{{ filter.values[0].url_to_add }}"
                      data-remove="{{ filter.values[0].url_to_remove }}">
                    <span class="xuw-check__box"></span><span class="xuw-check__label">{{ filter.label }}</span>
                  </label>
                {%- when 'list' -%}
                  {%- for value in filter.values -%}
                    <label class="xuw-check{% if value.count == 0 and value.active == false %} xuw-check--empty{% endif %}">
                      <input type="checkbox" class="xuw-fc xuw-fc--dynamic"
                        {% if value.active %}checked{% endif %}
                        {% if value.count == 0 and value.active == false %}disabled{% endif %}
                        data-add="{{ value.url_to_add }}" data-remove="{{ value.url_to_remove }}">
                      <span class="xuw-check__box"></span>
                      <span class="xuw-check__label">{{ value.label }}</span>
                      <span class="xuw-check__count">{{ value.count }}</span>
                    </label>
                  {%- endfor -%}
                {%- when 'price_range' -%}
                  <div class="xuw-price-range">
                    <div class="xuw-price-range__track">
                      <div class="xuw-price-range__fill" id="xuwPriceFill"></div>
                      <input type="range" class="xuw-range" id="xuwPriceMin"
                        min="{{ filter.range_min | divided_by: 100.0 }}" max="{{ filter.range_max | divided_by: 100.0 }}"
                        value="{{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 }}"
                        step="1" data-param="{{ filter.min_value.param_name }}" aria-label="Minimum price">
                      <input type="range" class="xuw-range" id="xuwPriceMax"
                        min="{{ filter.range_min | divided_by: 100.0 }}" max="{{ filter.range_max | divided_by: 100.0 }}"
                        value="{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 }}"
                        step="1" data-param="{{ filter.max_value.param_name }}" aria-label="Maximum price">
                    </div>
                    <div class="xuw-price-range__labels">
                      <span id="xuwPriceMinLbl">&#8364;{{ filter.min_value.value | default: filter.range_min | divided_by: 100.0 | round }}</span>
                      <span id="xuwPriceMaxLbl">&#8364;{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 | round }}</span>
                    </div>
                  </div>
              {%- endcase -%}
            </div>
          </div>
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}

