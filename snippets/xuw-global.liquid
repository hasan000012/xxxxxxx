{% comment %}
  XUW Global — snippets/xuw-global.liquid
  Loads XUW CSS/JS and renders the quick-buy modal + toast globally
  so they work on ALL collection pages, not just xuw-collection section.
{% endcomment %}

<link rel="stylesheet" href="{{ 'xuw-collection.css' | asset_url }}">

{%- comment %} ══ QUICK BUY MODAL — V5 ══ {% endcomment %}
<div id="xuw-modal-overlay" class="xuw-modal-overlay xuw-is-hidden"
     data-action="close-modal" aria-hidden="true">
  <div class="xuw-modal" role="dialog" aria-modal="true"
       aria-labelledby="xuw-modal-title" id="xuw-modal-inner">

    <button class="xuw-modal__close" data-action="close-modal"
            aria-label="Close" type="button">&times;</button>

    <div id="xuw-modal-loading" class="xuw-modal__loading">
      <div class="xuw-spinner"></div>
    </div>

    <div id="xuw-modal-content" class="xuw-is-hidden">

      <p  id="xuw-modal-vendor" class="xuw-modal__vendor"></p>
      <h2 id="xuw-modal-title"  class="xuw-modal__title"></h2>

      <div id="xuw-modal-mode-row" class="xuw-modal__mode-row xuw-is-hidden">
        <button class="xuw-modal__mode-btn is-active"
                data-action="modal-mode" data-mode="retail" type="button">Retail</button>
        <button class="xuw-modal__mode-btn"
                data-action="modal-mode" data-mode="wholesale" type="button">Wholesale</button>
      </div>

      <div id="xuw-modal-variants" class="xuw-modal__variants"></div>

      <div id="xuw-modal-price" class="xuw-modal__price-zone"></div>

      <div id="xuw-modal-tiers" class="xuw-modal__tiers xuw-is-hidden">
        <table class="xuw-ws-tier-table">
          <thead><tr><th>Spend</th><th>Discount</th><th>Status</th></tr></thead>
          <tbody>
            <tr data-tier-min="300"  data-tier-pct="3"> <td>&#8364;300+</td>  <td>3% off</td>  <td class="xuw-tier__status"></td></tr>
            <tr data-tier-min="500"  data-tier-pct="5"> <td>&#8364;500+</td>  <td>5% off</td>  <td class="xuw-tier__status"></td></tr>
            <tr data-tier-min="1000" data-tier-pct="10"><td>&#8364;1,000+</td><td>10% off</td> <td class="xuw-tier__status"></td></tr>
            <tr data-tier-min="2000" data-tier-pct="20"><td>&#8364;2,000+</td><td>20% off</td> <td class="xuw-tier__status"></td></tr>
          </tbody>
        </table>
        <p id="xuw-modal-ws-note" class="xuw-ws-live-note"></p>
      </div>

      <div class="xuw-modal__actions">
        <div class="xuw-modal__qty-row">
          <button class="xuw-qty-btn" data-action="qty-dec" aria-label="Decrease" type="button">&#8722;</button>
          <span   id="xuw-modal-qty" class="xuw-qty-val" aria-live="polite">1</span>
          <button class="xuw-qty-btn" data-action="qty-inc" aria-label="Increase" type="button">+</button>
        </div>
        <button id="xuw-modal-atc" class="xuw-btn--primary" data-action="modal-atc" type="button">
          + Add to Cart
        </button>
      </div>

    </div>
  </div>
</div>
<script src="{{ 'xuw-collection.js' | asset_url }}" defer></script>

{%- comment %} ══ PRODUCT PAGE CATEGORY NAV ══
  Rendered on product pages only. No Horizon base files touched (Rule 1).
{% endcomment %}
{%- if request.page_type == 'product' -%}
  {%- render 'xuw-product-schema', product: product -%}
  {%- render 'xuw-product-nav', product: product -%}
  <script>
    (function () {
      var nav = document.querySelector('.xuw-pnav');
      if (!nav) return;
      var target = document.querySelector('.product-information') ||
                   document.querySelector('main') ||
                   document.body;
      target.insertBefore(nav, target.firstChild);
    }());
  </script>
{%- endif -%}
