{% comment %}
  XUW Product Card — snippets/xuw-product-card.liquid — v10
  V10: V3 spec — dual price zones in DOM (Rule 11), sliding WS toggle,
  stock dot, single quick-buy CTA. Both .xuw-price-retail and
  .xuw-price-wholesale always exist in DOM. JS toggles .xuw-is-hidden.
{% endcomment %}

{%- liquid
  assign first_variant  = product.selected_or_first_available_variant
  assign sold_out       = false
  unless product.available
    assign sold_out = true
  endunless
  assign is_wholesale = false
  if product.tags contains 'wholesale' or product.tags contains 'Wholesale'
    assign is_wholesale = true
  endif
  assign moq = 1
  for tag in product.tags
    if tag contains 'moq-'
      assign moq_str = tag | remove: 'moq-'
      assign moq     = moq_str | plus: 0
    endif
  endfor
  assign retail_variant = nil
  assign ws_variant     = nil
  for v in product.variants
    assign v_t = v.title | downcase
    if v_t contains 'wholesale'
      if ws_variant == nil
        assign ws_variant = v
      endif
    else
      if retail_variant == nil
        assign retail_variant = v
      endif
    endif
  endfor
  if retail_variant == nil
    assign retail_variant = first_variant
  endif
  assign img_alt     = product.featured_media.alt | default: product.title | escape
  assign tags_string = product.tags | join: ',' | downcase
-%}

<div class="xuw-card{% if sold_out %} xuw-card--soldout{% endif %}"
  data-product-id="{{ product.id }}"
  data-handle="{{ product.handle }}"
  data-wholesale="{{ is_wholesale }}"
  data-moq="{{ moq }}"
  data-current-mode="retail"
  data-tags="{{ tags_string }}"
  data-product-type="{{ product.type | downcase | escape }}"
  data-vendor="{{ product.vendor | downcase | escape }}"
  data-available="{{ product.available }}"
  data-price="{{ retail_variant.price }}">

  <div class="xuw-card__img-wrap">
    <a href="{{ product.url }}">
      {%- if product.featured_media -%}
        <img class="xuw-card__img"
          src="{{ product.featured_media | image_url: width: 400 }}"
          alt="{{ img_alt }}"
          width="400" height="400"
          loading="lazy">
      {%- else -%}
        <div class="xuw-card__img-placeholder" aria-hidden="true">
          <span>{{ product.title | slice: 0, 2 | upcase }}</span>
        </div>
      {%- endif -%}
    </a>

    {%- if product.tags contains 'new' or product.tags contains 'NEW' -%}
      <span class="xuw-badge xuw-badge--new">NEW</span>
    {%- elsif product.tags contains 'hot' -%}
      <span class="xuw-badge xuw-badge--hot">HOT</span>
    {%- elsif product.tags contains 'sale' -%}
      <span class="xuw-badge xuw-badge--sale">SALE</span>
    {%- endif -%}
    {%- if product.tags contains 'eco' -%}
      <span class="xuw-badge xuw-badge--eco">ECO</span>
    {%- endif -%}
    {%- if is_wholesale -%}
      <span class="xuw-badge xuw-badge--ws">WS</span>
    {%- endif -%}

    <span class="xuw-card__stock-dot{% unless product.available %} is-oos{% endunless %}"></span>
  </div>

  <div class="xuw-card__body">

    {%- if show_vendor and product.vendor != blank -%}
      <p class="xuw-card__vendor">
        <a href="/collections/all?vendor={{ product.vendor | url_encode }}">{{ product.vendor }}</a>
      </p>
    {%- endif -%}

    <p class="xuw-card__name">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </p>

    <div class="xuw-card__price-zone" aria-live="polite">

      <div class="xuw-price-retail">
        {%- if retail_variant.compare_at_price > retail_variant.price -%}
          <span class="xuw-price__compare">{{ retail_variant.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="xuw-price__current">
          {%- if product.price_varies -%}From {{ product.price_min | money }}
          {%- else -%}{{ retail_variant.price | money }}
          {%- endif -%}
        </span>
      </div>

      {%- if is_wholesale -%}
      <div class="xuw-price-wholesale xuw-is-hidden">
        <span class="xuw-price__retail-crossed">{{ retail_variant.price | money }}</span>
        <div class="xuw-price__ws-row">
          <span class="xuw-price__ws-amount">—</span>
          <span class="xuw-pill xuw-pill--gold">WS</span>
        </div>
        <p class="xuw-price__moq-note">
          Typical order: <strong class="xuw-moq-qty">{{ moq }}</strong>+ units
        </p>
      </div>
      {%- endif -%}

    </div>

    {%- if is_wholesale -%}
    <div class="xuw-card__ws-toggle-row">
      <button
        class="xuw-ws-toggle"
        data-action="card-mode"
        data-handle="{{ product.handle }}"
        aria-pressed="false"
        aria-label="Toggle wholesale pricing"
        type="button">
        <span class="xuw-ws-toggle__track">
          <span class="xuw-ws-toggle__pill"></span>
        </span>
        <span class="xuw-ws-toggle__label">Wholesale</span>
      </button>
    </div>
    {%- endif -%}

    {%- assign visible_variants = 0 -%}
    {%- for v in product.variants -%}
      {%- assign v_lower = v.title | downcase -%}
      {%- unless v_lower contains 'wholesale' -%}
        {%- assign visible_variants = visible_variants | plus: 1 -%}
      {%- endunless -%}
    {%- endfor -%}
    {%- if visible_variants > 1 -%}
      <p class="xuw-card__variants-hint">{{ visible_variants }} options</p>
    {%- endif -%}

    {%- if sold_out -%}
      <button class="xuw-btn xuw-btn--primary xuw-btn--full"
        disabled aria-disabled="true" type="button">Out of Stock</button>
    {%- else -%}
      <button
        class="xuw-btn xuw-btn--primary xuw-btn--full"
        data-action="quick-buy"
        data-handle="{{ product.handle }}"
        aria-label="Quick buy {{ product.title | escape }}"
        type="button">+ Add to Cart</button>
    {%- endif -%}

  </div>
</div>
